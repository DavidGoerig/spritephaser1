# Copy this file to .env and fill in your credentials.
# Never commit .env to git — it's already in .gitignore.

# ── Meshy AI (3D model generation) ──────────────────────────────────────────
# Get your key at: https://www.meshy.ai/
MESHY_API_KEY=your_key_here

# ── Stability AI (2D sprite generation — Stage 2 only) ───────────────────────
STABILITY_API_KEY=your_key_here

# ── Runtime binaries ──────────────────────────────────────────────────────────
# Node.js executable (must be in PATH, or provide full path)
NODE_BIN=node

# Blender executable (for headless GLB → render pipeline, Stage 2)
# BLENDER_PATH=C:/Program Files/Blender Foundation/Blender 4.1/blender.exe

# ── Pipeline directory paths (relative to project root) ──────────────────────
PIPELINE_DIR=scripts/pipeline
OUTPUT_DIR=public/characters

# ── Spritesheet geometry ──────────────────────────────────────────────────────
# Each animation slot is a 512×256 spritesheet:
#   DIRECTIONS rows × FRAME_COUNT columns of FRAME_SIZE×FRAME_SIZE cells
FRAME_COUNT=8
FRAME_SIZE=64
DIRECTIONS=4

# ── Meshy polling settings ────────────────────────────────────────────────────
MESHY_POLL_INTERVAL=15      # seconds between status polls
MESHY_MAX_WAIT=1800         # max seconds to wait per task (30 min)

# ── Stability AI generation settings (Stage 2) ────────────────────────────────
MAX_CONCURRENT=4            # parallel image generation requests
RATE_LIMIT_RPM=60           # requests per minute cap
# USE_REPLICATE=0           # set to 1 to use Replicate instead of Stability AI
# REPLICATE_API_TOKEN=r8_…
